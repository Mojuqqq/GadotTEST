[sub_resource type="GDScript" id="GDScript_m1htj"]
script/source = "extends Node2D

# === Ссылки на узлы ===
@onready var player = $Player
@onready var enemies = $Enemies  # Node2D для хранения врагов

# === Переменные ===
@export var enemy_scene: PackedScene  # сцена врага (перетащить в Inspector)
@export var enemies_count: int = 5    # количество врагов

# === Настройка уровня ===
func _ready():
	# Устанавливаем размеры игрового поля
	var world_size = 2000  # поле 2000x2000
	
	# Если есть TileMap, можно настроить его
	# или просто включить ограничения камеры
	if player and player.has_node(\"Camera2D\"):
		var camera = player.get_node(\"Camera2D\")
		camera.limit_left = -world_size
		camera.limit_right = world_size
		camera.limit_top = -world_size
		camera.limit_bottom = world_size
		
	# Добавляем игрока в группу \"Player\"
	if player and not player.is_in_group(\"Player\"):
		player.add_to_group(\"Player\")
	
	# Спавним врагов
	spawn_enemies()
	
	print(\"Главная сцена загружена!\")
	print(\"Игрок: \", player.name, \" с HP = \", player.current_hp)

# === Спавн врагов ===
func spawn_enemies():
	if enemy_scene == null:
		print(\"Ошибка: enemy_scene не назначена!\")
		return
	
	for i in range(enemies_count):
		var enemy = enemy_scene.instantiate()
		enemy.add_to_group(\"Enemies\")  # добавляем в группу
		add_child(enemy)
		enemy.global_position = get_random_spawn_position()
		
		# Ставим на случайную позицию
		enemy.global_position = get_random_spawn_position()
		
		print(\"Враг \", i + 1, \" создан на позиции: \", enemy.global_position)

# === Генерация случайной позиции ===
func get_random_spawn_position() -> Vector2:
	# Радиус спавна от центра
	var spawn_radius = 400.0
	var angle = randf() * 2 * PI
	var x = cos(angle) * spawn_radius * randf_range(0.5, 1.0)
	var y = sin(angle) * spawn_radius * randf_range(0.5, 1.0)
	return Vector2(x, y)

# === Проверка всех врагов ===
func check_enemies_alive():
	var enemies_list = get_tree().get_nodes_in_group(\"Enemies\")
	if enemies_list.size() == 0:
		print(\"Все враги уничтожены! Поздравляю!\")

# === Очистка уровня ===
func clear_level():
	# Удаляем всех врагов
	var enemies_list = get_tree().get_nodes_in_group(\"Enemies\")
	for enemy in enemies_list:
		enemy.queue_free()

# === Перезапуск уровня ===
func restart_level():
	print(\"Перезапуск уровня...\")
	get_tree().reload_current_scene()

# === Функция для отладки ===
func _process(delta):
	# Проверка по нажатию клавиши R - перезапуск
	if Input.is_key_pressed(KEY_R):
		restart_level()
	
	# Проверка по нажатию клавиши E - спавн нового врага
	if Input.is_key_pressed(KEY_E):
		spawn_enemy_at_cursor()

# === Спавн врага под курсором (для тестов) ===
func spawn_enemy_at_cursor():
	if enemy_scene == null:
		return
	
	var enemy = enemy_scene.instantiate()
	add_child(enemy)
	enemy.global_position = get_global_mouse_position()
	print(\"Враг создан под курсором на позиции: \", enemy.global_position)
"

